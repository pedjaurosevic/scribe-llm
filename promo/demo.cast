[0.009366, "o", "   ┌──────────────────────────────────────────────────────┐\r\n   │  Scribe — grammar-enforced tool calls, cited answers  │\r\n   └──────────────────────────────────────────────────────┘\r\n"]
[0.009519, "o", "\u001b[0m\r\n"]
[1.510803, "o", "\r\n\u001b[1;33m── Capabilities ──\u001b[0m\r\n\r\n"]
