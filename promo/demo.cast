[11.256856, "o", "  \u001b[38;2;184;187;38m●\u001b[0m server  \u001b[4;94mhttp://127.0.0.1:18083/v1\u001b[0m  \u001b[38;2;131;165;152mgemma-\u001b[0m\u001b[38;2;131;165;152m4\u001b[0m\u001b[38;2;131;165;152m-12B-it-Q4_K_M.gguf\u001b[0m\r\n"]
