[14.069509, "o", "\r\n\u001b[1;33m── 1 — tool calls are grammar-constrained ──\u001b[0m\r\n\r\n"]
[14.870953, "o", "\u001b[0;36m# A GBNF grammar is generated from the tool schemas. Under it, llama.cpp\u001b[0m\r\n"]
[15.77223, "o", "\u001b[0;36m# can only sample a well-formed call — a malformed one has zero probability.\u001b[0m\r\n"]
[16.673454, "o", "\u001b[1;36mscribe-demo\u001b[0m$ p"]
[16.704507, "o", "y"]
[16.735739, "o", "t"]
